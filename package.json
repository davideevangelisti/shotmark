{
  "name": "shotmark",
  "version": "0.1.5",
  "private": true,
  "description": "In-browser screenshot annotator + beautifier. Privacy-first: nothing leaves your device.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4317",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test": "npm run typecheck && npm run test:unit && npm run build && npm run test:e2e",
    "icons": "node scripts/generate-icons.mjs",
    "vendor-tesseract": "node scripts/vendor-tesseract.mjs",
    "bump": "node scripts/bump-version.mjs",
    "build:ext": "node scripts/bump-version.mjs && node scripts/pack-extension.mjs",
    "hero": "node scripts/generate-hero.mjs",
    "build:site": "node scripts/build-site.mjs"
  },
  "dependencies": {
    "fabric": "^6.5.1",
    "jspdf": "^4.2.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^25.9.3",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
